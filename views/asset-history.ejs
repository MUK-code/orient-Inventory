<%- include('layout') %>

<div class="container mt-4">
  <h2>Asset History</h2>

  <table class="table table-bordered table-striped">
    <thead class="table-dark">
      <tr>
        <th>User</th>
        <th>Employee ID</th>
        <th>Date</th>
        <th>Action</th>
      </tr>
    </thead>

    <tbody>
      <% if (history.length === 0) { %>
        <tr>
          <td colspan="4" class="text-center">No history found</td>
        </tr>
      <% } %>

      <% history.forEach(row => { %>
        <tr>
          <td><%= row.name %></td>
          <td><%= row.employee_id %></td>
          <td><%= row.action_date %></td>
          <td>
            <% if (row.action_type === 'allocated') { %>
              <span class="badge bg-danger">Allocated</span>
            <% } else if (row.action_type === 'returned') { %>
              <span class="badge bg-success">Returned</span>
            <% } else { %>
              <span class="badge bg-secondary"><%= row.action_type %></span>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <a href="/assets" class="btn btn-secondary">← Back</a>
</div>