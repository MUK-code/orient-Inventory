<%- include('layout') %>

<div class="card">
  <div style="display:flex;justify-content:space-between;align-items:center;gap:20px;flex-wrap:wrap">
    <div>
      <h2 style="margin:0 0 6px 0">Inventory Dashboard</h2>
      <p style="margin:0;color:#475569">Overview of assets and quick actions</p>
    </div>
    <div style="display:flex;gap:12px;align-items:center">
      <a href="/add-asset" class="btn">+ Add New Asset</a>
      <a href="/assets" class="btn">View Assets</a>
      <a href="/allocations" class="btn">Allocations</a>
      <a href="/model-summary" class="btn">Model Summary</a>
      <a href="/employee-assets" class="btn">Employee Search</a>
      <a href="/assets" class="btn">Asset History</a>
    </div>
  </div>

  <div style="display:flex;gap:16px;margin-top:18px;flex-wrap:wrap">
    <div style="flex:1;min-width:180px;padding:18px;border-radius:8px;background:linear-gradient(90deg,#ffffff,#fbfdff);box-shadow:0 6px 18px rgba(2,6,23,0.06);">
      <div style="font-size:13px;color:#64748b">Total Assets</div>
      <div style="font-size:28px;font-weight:700;margin-top:6px"> <%= total %> </div>
    </div>
    <div style="flex:1;min-width:180px;padding:18px;border-radius:8px;background:#fff;box-shadow:0 6px 18px rgba(2,6,23,0.04);">
      <div style="font-size:13px;color:#64748b">Allocated</div>
      <div id="allocatedCount" style="font-size:22px;font-weight:700;margin-top:6px">--</div>
    </div>
    <div style="flex:1;min-width:180px;padding:18px;border-radius:8px;background:#fff;box-shadow:0 6px 18px rgba(2,6,23,0.04);">
      <div style="font-size:13px;color:#64748b">In Stock</div>
      <div id="inStockCount" style="font-size:22px;font-weight:700;margin-top:6px">--</div>
    </div>
  </div>
</div>

<div class="card">
  <h3 style="margin-top:0">Reports</h3>
  <p style="color:#64748b;margin-top:4px;margin-bottom:8px">Search once and open any report</p>
  <div style="display:flex;flex-direction:column;gap:8px">
    <input id="sharedSearch" class="input" placeholder="Search name, emp id, asset, type, brand, model, serial" />
    <div style="display:flex;gap:8px;flex-wrap:wrap">
      <button class="btn" onclick="openReport('allocations')">Open Allocations</button>
      <button class="btn" onclick="openReport('returns')">Open Returns</button>
      <button class="btn" onclick="openReport('in-stock')">Open In-Stock</button>
    </div>
    <!-- Model Summary and Employee Search moved to header buttons -->
  </div>
</div>

<script>
  // helper to fetch metrics and update the UI
  function fetchCounts(){
    fetch('/api/reports/in-stock-count')
      .then(r => r.json())
      .then(j => { if (j && j.count !== undefined) document.getElementById('inStockCount').innerText = j.count; else document.getElementById('inStockCount').innerText = 'N/A'; })
      .catch(() => { document.getElementById('inStockCount').innerText = 'N/A'; });

    fetch('/api/reports/allocated-count')
      .then(r => r.json())
      .then(j => { if (j && j.count !== undefined) document.getElementById('allocatedCount').innerText = j.count; else document.getElementById('allocatedCount').innerText = 'N/A'; })
      .catch(() => { document.getElementById('allocatedCount').innerText = 'N/A'; });
  }

  // initial load and periodic refresh every 30s
  fetchCounts();
  setInterval(fetchCounts, 30000);

  function openReport(type){
    const q = document.getElementById('sharedSearch').value.trim();
    const base = {
      'allocations': '/reports-allocations.html',
      'returns': '/reports-returns.html',
      'in-stock': '/reports-in-stock.html'
    }[type] || '/reports-allocations.html';
    const url = q ? `${base}?search=${encodeURIComponent(q)}` : base;
    window.open(url, '_blank');
  }
</script>



<%- include('footer') %>